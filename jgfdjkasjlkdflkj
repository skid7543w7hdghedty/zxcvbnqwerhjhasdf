    ["Improving"] = "Improving",
}

local function TRANSLATE_STABILITY_STATUS(STATUS)
    if not STATUS then return nil end
    STATUS = HTML_DECODE(STATUS)
    STATUS = STATUS:gsub("^%s+", ""):gsub("%s+$", "")
    if STATUS == "" then return nil end
    return STABILITY_STATUS_MAP[STATUS] or STATUS
end

local function NORMALIZE_RANGE_TEXT(RANGE_TEXT)
    if not RANGE_TEXT then return nil end
    RANGE_TEXT = HTML_DECODE(RANGE_TEXT)
    RANGE_TEXT = RANGE_TEXT:gsub("^%s+", ""):gsub("%s+$", "")
    RANGE_TEXT = RANGE_TEXT:gsub("%[", ""):gsub("%]", "")
    RANGE_TEXT = RANGE_TEXT:gsub(",", "")
    RANGE_TEXT = RANGE_TEXT:gsub("%s*%-%s*", "-")
    if RANGE_TEXT == "" or RANGE_TEXT == "N/A" then return nil end
    return RANGE_TEXT
end

local function BUILD_STABILITY_TEXT(STATUS_TEXT, RANGE_TEXT)
    local STATUS = TRANSLATE_STABILITY_STATUS(STATUS_TEXT)
    if not STATUS then return nil, nil end
    local RANGE = NORMALIZE_RANGE_TEXT(RANGE_TEXT)
    return STATUS, RANGE
end

local function NORMALIZE_FALLBACK_STABILITY(TEXT)
    if not TEXT then return nil, nil end
    local RAW_STATUS, RAW_RANGE = HTML_DECODE(TEXT):match("^%s*([^,]+)%s*,%s*(.+)%s*$")
    if not RAW_STATUS then
        local STATUS = TRANSLATE_STABILITY_STATUS(TEXT)
        return STATUS, nil
    end
    return BUILD_STABILITY_TEXT(RAW_STATUS, RAW_RANGE)
end

local function REBUILD_FALLBACK_DATA()
    ITEM_VALUES = {}
    ITEM_STABILITIES = {}
    ITEM_DEMANDS = {}
    ITEM_RANGES = {}
    for NAME, VALUE in pairs(ancientValues) do
        ITEM_VALUES[NORMALIZE_LOOKUP_NAME(NAME)] = VALUE
    end
    for NAME, STABILITY in pairs(stabilityValues) do
        local lookupName = NORMALIZE_LOOKUP_NAME(NAME)
        local status, range = NORMALIZE_FALLBACK_STABILITY(STABILITY)
        if status then
            ITEM_STABILITIES[lookupName] = status
        end
        if range then
            ITEM_RANGES[lookupName] = range
        end
    end
end

local function PARSE_PAGE_DATA(HTML)
    local COUNT = 0
    for RAW_NAME, RAW_VALUE, RAW_RANGE, RAW_STABILITY, RAW_DEMAND in HTML:gmatch('data%-name=\'(.-)\'.-itemvalue">(.-)</b>.-itemrange">(.-)</b>.-itemstability">(.-)</b>.-Demand%s*%-%s*<b>(%d+)</b>') do
        local NAME = NORMALIZE_DISPLAY_NAME(RAW_NAME)
        local VALUE = tonumber((HTML_DECODE(RAW_VALUE):gsub(",", ""):gsub("%s+", "")))
        local STATUS, RANGE = BUILD_STABILITY_TEXT(RAW_STABILITY, RAW_RANGE)
        local DEMAND = tonumber(RAW_DEMAND)
        if NAME ~= "" then
            local LOOKUP_NAME = NORMALIZE_LOOKUP_NAME(NAME)
            if VALUE then ITEM_VALUES[LOOKUP_NAME] = VALUE end
            if STATUS then ITEM_STABILITIES[LOOKUP_NAME] = STATUS end
            if RANGE then ITEM_RANGES[LOOKUP_NAME] = RANGE end
            if DEMAND then ITEM_DEMANDS[LOOKUP_NAME] = DEMAND end
            COUNT = COUNT + 1
        end
    end
    return COUNT
end

local function REFRESH_VALUES_FROM_SUPREME()
    REBUILD_FALLBACK_DATA()
    local TOTAL_PARSED = 0
    for _, URL in ipairs(SUPREME_URLS) do
        local OK, HTML = pcall(function() return game:HttpGet(URL) end)
        if OK and HTML and HTML ~= "" then
            TOTAL_PARSED = TOTAL_PARSED + PARSE_PAGE_DATA(HTML)
        end
    end
    return TOTAL_PARSED
end

