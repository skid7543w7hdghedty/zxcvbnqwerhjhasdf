local function HTML_DECODE(TEXT)
    if not TEXT then return "" end
    TEXT = TEXT:gsub("&#039;", "'")
    TEXT = TEXT:gsub("&quot;", '"')
    TEXT = TEXT:gsub("&amp;", "&")
    TEXT = TEXT:gsub("&lt;", "<")
    TEXT = TEXT:gsub("&gt;", ">")
    TEXT = TEXT:gsub("&nbsp;", " ")
    return TEXT
end

local function NORMALIZE_DISPLAY_NAME(NAME)
    NAME = HTML_DECODE(NAME)
    NAME = NAME:gsub("<.->", "")
    NAME = NAME:gsub("^%s+", "")
    NAME = NAME:gsub("%s+$", "")
    NAME = NAME:gsub("%s+", " ")
    NAME = NAME:gsub("^C%.%s*", "Chroma ")
    NAME = NAME:gsub("^Travelers ", "Traveler's ")
    NAME = NAME:gsub("^Vampires ", "Vampire's ")
    NAME = NAME:gsub("^Winters ", "Winter's ")
    NAME = NAME:gsub("^Hallows ", "Hallow's ")
    return NAME
end

local function NORMALIZE_LOOKUP_NAME(NAME)
    return string.lower(NORMALIZE_DISPLAY_NAME(NAME))
end

local ITEM_VALUES = {}
local ITEM_STABILITIES = {}
local ITEM_DEMANDS = {}
local ITEM_RANGES = {}

local STABILITY_STATUS_MAP = {
    ["Overpaid For"] = "Overpaid For",
    ["Overpaid"] = "Overpaid For",
    ["Underpaid For"] = "Underpaid For",
    ["Underpaid"] = "Underpaid For",
    ["Undepaid"] = "Underpaid For",
