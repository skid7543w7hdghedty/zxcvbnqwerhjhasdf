local function BUILD_STABILITY_DISPLAY(STATUS, RANGE)
    if not STATUS then
        local color = stabilityColors["Unknown"]
        local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
        return string.format('<font color="rgb(%d,%d,%d)">Unknown ~</font>', r, g, b)
    end

    local color = GET_STABILITY_COLOR(STATUS)
    local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
    local arrow = GET_STABILITY_ARROW(STATUS)

    if STATUS == "Stable" then
        return string.format('<font color="rgb(%d,%d,%d)">%s %s</font>', r, g, b, STATUS, arrow)
    else
        local displayText = STATUS .. " " .. arrow
        if RANGE and RANGE ~= "" then
            displayText = displayText .. ", " .. RANGE
        end
        return string.format('<font color="rgb(%d,%d,%d)">%s</font>', r, g, b, displayText)
    end
end

